# Server Configuration
PORT=8081
NODE_ENV=development

# Aggregator Database (Supabase)
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SECRET_KEY=your-aggregator-service-role-key

# JWT Configuration
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-must-be-random
JWT_EXPIRES_IN_SECONDS=86400

# Backend Base URL
BACKEND_BASE_URL=http://127.0.0.1:8081

# CORS — comma-separated list of allowed frontend origins (C-3/C-4 fix)
# Production example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
